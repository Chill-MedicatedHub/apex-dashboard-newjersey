# LeafLink API token. Generate one in LeafLink → Developer Options.
# This is sensitive — do NOT commit your actual .env to git.
LEAFLINK_TOKEN=""

# How many days of order history to pull. Default 365 (one year).
LEAFLINK_DAYS_BACK=365

# Results per API page. Default 100.
LEAFLINK_PAGE_SIZE=100

# State filter — only orders shipping to this state are kept.
# Default "NJ". Use "" to keep orders from all states.
LEAFLINK_STATE="NJ"

# Which LeafLink environment to use.
# Production: app.leaflink.com  (default)
# Sandbox:    www.sandbox.leaflink.com
LEAFLINK_DOMAIN="app.leaflink.com"

# How often the refresh loop pulls fresh data. Default 15 minutes.
REFRESH_MINUTES=15
